# 로컬 개발용 설정 예시 (복사 후 application-local.yml 로 저장 후 사용)
# 실행: --spring.profiles.active=local 또는 환경변수 SPRING_PROFILES_ACTIVE=local
spring:
  data:
    mongodb:
      uri: mongodb://localhost:27017/blog3
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB

# 로컬에서는 쿠키 secure 비활성 (http)
server:
  servlet:
    session:
      cookie:
        http-only: true
        secure: false
        same-site: lax

logging:
  level:
    com.myMongoTest: DEBUG
